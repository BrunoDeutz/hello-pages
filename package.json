{
  "name": "hello-pages",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently \"npm --prefix server run dev\" \"npm --prefix client run dev\"",
    "start": "node server/index.js",
    "build": "npm --prefix client run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
